# ============================================================
# CertPrepAgents — Environment Configuration
# ============================================================
# Copy this file to use with dotnet user-secrets:
#   dotnet user-secrets set "GITHUB_TOKEN" "your-token-here"
#
# Or set as environment variables.

# REQUIRED: GitHub personal access token with Models access
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=your-github-pat-here

# OPTIONAL: OpenTelemetry collector endpoint for distributed tracing
# Default: http://localhost:4317
# Otel__Endpoint=http://localhost:4317

# OPTIONAL: SMTP configuration for real email delivery
# Without these, emails are logged to console instead
# Smtp__Host=smtp.example.com
# Smtp__Port=587
# Smtp__Username=your-smtp-user
# Smtp__Password=your-smtp-password
# Smtp__From=certprep@agentsleague.dev
