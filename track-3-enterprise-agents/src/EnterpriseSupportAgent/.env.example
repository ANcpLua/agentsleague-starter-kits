# ============================================================
# Enterprise Support Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file with real credentials.
# ============================================================

# --- Azure Bot / Microsoft Agents SDK ---
BOT_ID=<your-azure-bot-app-id>
BOT_DOMAIN=<your-bot-domain>
MICROSOFT_APP_ID=<your-microsoft-app-id>
MICROSOFT_APP_PASSWORD=<your-microsoft-app-password>
MICROSOFT_APP_TENANT_ID=<your-tenant-id>

# --- AI Provider (choose one) ---
# Option 1: GitHub Models (free tier — recommended for evaluation)
LANGUAGE_MODEL_NAME=openai/gpt-4.1-mini
LANGUAGE_MODEL_ENDPOINT=https://models.github.ai/inference
LANGUAGE_MODEL_KEY=<your-github-token>

# Option 2: Azure OpenAI
# LANGUAGE_MODEL_NAME=gpt-4o
# LANGUAGE_MODEL_ENDPOINT=https://<your-resource>.openai.azure.com
# LANGUAGE_MODEL_KEY=<your-azure-openai-key>

# --- Storage ---
BlobsStorageOptions__StorageAccountName=<your-storage-account>
BlobsStorageOptions__ContainerName=state

# --- MCP Observability (optional — connects to qyl platform) ---
McpObservability__Endpoint=https://mcp.qyl.info/sse
